# Copy to `.env` for local development. Never commit real secrets.

# --- Contact form → Resend (`server/api/contact.post.ts`) ---
NUXT_RESEND_API_KEY=
NUXT_CONTACT_TO_EMAIL=
NUXT_CONTACT_FROM_EMAIL=

# --- Site URL (canonical URLs, OG defaults in `nuxt.config.ts`) ---
# NUXT_PUBLIC_SITE_URL=https://example.com

# --- Sanity project (optional overrides; defaults in `nuxt.config.ts` / studio) ---
# SANITY_PROJECT_ID=
# SANITY_DATASET=production
# SANITY_API_VERSION=2025-01-01

# --- Two different tokens (do not confuse them) ---
#
# SANITY_READ_TOKEN — used only by the Nuxt server (`server/utils/sanityFetch.ts`)
# when `useToken: true` (protected project password hashes + full project GROQ).
# Use a read-only token with the narrowest role that can read those fields.
# Required on the host if you use password-protected case studies.
SANITY_READ_TOKEN=
#
# SANITY_API_TOKEN — used only by local tooling (`scripts/upload-sanity-project-images.mjs`)
# for writes/uploads. Use a separate write-capable token; never expose it to the browser.
SANITY_API_TOKEN=

# --- Password-protected projects (`server/utils/projectAccess.ts`) ---
# Required in production (min 16 characters). Signs the HttpOnly unlock cookie.
PROJECT_UNLOCK_SECRET=

# --- Abuse protection (`server/utils/requestSecurity.ts`) ---
# Required for both the contact form and protected-project unlock flow.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
TURNSTILE_SECRET_KEY=
NUXT_PUBLIC_TURNSTILE_SITE_KEY=
# Set to "true" to temporarily disable Turnstile verification
NUXT_PUBLIC_TURNSTILE_DISABLED=
