# Public site URL (used for OG/meta tags).
NUXT_PUBLIC_SITE_URL=https://bryanxmendez.com

# Sanity project connection. Defaults are baked into nuxt.config.ts;
# only override these for different deploys / forks.
SANITY_PROJECT_ID=ns0czoug
SANITY_DATASET=production
SANITY_API_VERSION=2025-01-01

# Optional Sanity read token. Required if you move the `password`
# field (or any other private data) behind a non-public dataset role.
# The server-side unlock endpoint uses this token when set.
SANITY_READ_TOKEN=

# Secret used to sign the project-unlock HttpOnly cookie (HMAC-SHA256).
# Must be at least 16 characters. REQUIRED in production.
# Generate: `openssl rand -base64 32`
PROJECT_UNLOCK_SECRET=
